# mt5-forward トラック定義（雛形）— コピーして tracks/tentei-himo.env を作成（実体は .gitignore 除外）
#   cp tracks/tentei-himo.env.example tracks/tentei-himo.env
#
# 非機密のみ。broker master パスワードは docker secret（secrets/titanfx_demo1_password）で注入（NF-002）。
# 注: CUSTOM_USER は KasmVNC のブラウザ認証ユーザー名。broker の investor ログイン（requirements §5.3）
#     とは別概念のため、紛らわしい "investor" は使わず webui とする。
CUSTOM_USER=webui
TRACK_NAME=tentei-himo
MT5_SERVER=TitanFX-Demo
MT5_LOGIN=<デモ口座番号>
SYMBOL=USDJPY
TIMEFRAME=M5
MAGIC=26060801
EA_FILE=TenteiHimo_Live.ex5
INP_RISK_PCT=1.0
